---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum — Alps Agency" lockHero={false}>
  <section class="legal">
    <a href="/" class="legal-back">&larr; Zur&uuml;ck zur Startseite</a>
    <h1>Impressum</h1>

    <h2>Angaben gem&auml;&szlig; &sect; 5 DDG</h2>
    <p>
      Alps Agency<br />
      Inhaber: J. Alps<br />
      Sch&ouml;naugasse 14<br />
      8010 Graz<br />
      &Ouml;sterreich
    </p>

    <h2>Kontakt</h2>
    <p>
      E-Mail: <a href="mailto:ALPSAGENCY@proton.me">ALPSAGENCY@proton.me</a>
    </p>

<h2>Verantwortlich f&uuml;r den Inhalt gem&auml;&szlig; &sect; 18 Abs. 2 MStV</h2>
    <p>
      J. Alps<br />
      Sch&ouml;naugasse 14, 8010 Graz, &Ouml;sterreich
    </p>

    <h2>Haftung f&uuml;r Inhalte</h2>
    <p>
      Als Diensteanbieter sind wir gem&auml;&szlig; &sect; 7 Abs. 1 DDG f&uuml;r eigene Inhalte
      auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. Nach &sect;&sect; 8 bis 10
