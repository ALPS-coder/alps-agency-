---
import '../styles/global.css';
import { useTranslations, defaultLang, type Lang } from '../i18n';
import LoadingScreen from '../components/LoadingScreen.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  /** Hero-Scroll-Gate aktiv (Startseite). Rechtsseiten setzen false → normal scrollbar. */
  lockHero?: boolean;
}

const { title, description, lang = defaultLang, lockHero = true } = Astro.props;
const t = useTranslations(lang);

const metaTitle = title ?? t('meta.title');
const metaDesc = description ?? t('meta.description');
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/logo/alps-logo.jpg', Astro.site);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Alps Agency',
  url: Astro.site?.href,
  logo: ogImage.href,
  description: metaDesc,
  areaServed: 'DE',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Sofort sperren: Sektionen sind nur über den 3D-Marquee-Flug erreichbar (kein
         Scrollen im Hero). Nur mit JS — ohne JS bleibt die Seite normal scrollbar.
         Nur Desktop (≥768px): auf dem Handy bleibt die Seite normal/ruhig scrollbar.
         Rechtsseiten (lockHero=false) setzen nur 'js' und bleiben frei scrollbar. -->
    {lockHero
      ? <script is:inline>document.documentElement.classList.add('js'); if (window.matchMedia('(min-width: 768px)').matches) document.documentElement.classList.add('section-locked');</script>
      : <script is:inline>document.documentElement.classList.add('js');</script>}

    <title>{metaTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical.href} />

    <!-- hreflang (EN-Routing folgt; aktuell Platzhalter auf Root) -->
    <link rel="alternate" hreflang="de" href={canonical.href} />
    <link rel="alternate" hreflang="en" href={canonical.href} />
    <link rel="alternate" hreflang="x-default" href={canonical.href} />

    <!-- Icons & Theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />
    <meta name="theme-color" content="#0a1628" />
    <meta name="color-scheme" content="dark" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alps Agency" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content={t('meta.og_alt')} />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <meta name="twitter:image" content={ogImage.href} />

    <!-- Fonts: Space Grotesk (Display) + Satoshi (Body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
  </head>

  <body>
    <a href="#main" class="skip-link">{t('nav.skip')}</a>

    <div class="grid-layer bg-grid mask-radial" aria-hidden="true"></div>

    <span id="top" class="anchor-top" aria-hidden="true"></span>
    <Header lang={lang} />

    <main id="main">
      <slot />
    </main>

    <Footer lang={lang} />

    <LoadingScreen lang={lang} />

    <script>
      // Kachel-Flug-Landung: Wenn man per 3D-Flug in einer Sektion ankommt, soll sie
      // SOFORT komplett sichtbar sein (keine Einblend-Animation im Lande-Moment).
      // Dafür die [data-reveal]-Elemente der Ziel-Sektion final setzen und nur DEREN
      // ScrollTrigger killen — andere Sektionen animieren beim Scrollen weiter normal.
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      window.addEventListener('flight-land', (e) => {
        const id = (e as CustomEvent).detail?.id as string | undefined;
        if (!id) return;
        const section = document.getElementById(id);
        if (!section) return;
        section.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
          el.style.opacity = '1';
          el.style.transform = 'none';
        });
        ScrollTrigger.getAll().forEach((t) => {
          const trg = t.trigger as Element | undefined;
          if (trg && section.contains(trg)) t.kill();
        });
      });
    </script>

    <script>
      // -------- Scroll-Gate: Sektionen NUR über den 3D-Marquee-Flug --------
      // Solange der Hero "gesperrt" ist (html.section-locked), kann man nicht in die
      // Sektionen scrollen — man MUSS eine Marquee-Kachel klicken (Header-/CTA-Links
      // lösen denselben Flug aus). In den Sektionen wird frei gescrollt; ganz oben am
      // Hero (Button ODER Hochscrollen) sperrt es wieder.
      const root = document.documentElement;
      // Nur auf der Startseite aktiv. Rechtsseiten starten ohne 'section-locked' → inert.
      if (root.classList.contains('section-locked')) {
      // Beispiele bewusst NICHT dabei: es ist ein eigenes Overlay (kein Scroll-/Flug-Ziel).
      const SECTION_IDS = new Set(['services', 'work', 'pricing', 'faq', 'contact']);
      let flying = false;
      const isLocked = () => root.classList.contains('section-locked');
      const lock = () => root.classList.add('section-locked');
      const unlock = () => {
        root.classList.remove('section-locked');
        // Die Sektionen waren ausgeblendet (display:none) → ScrollTrigger-Positionen sind
        // veraltet. Jetzt, da sie wieder im Layout sind, neu vermessen.
        import('gsap/ScrollTrigger').then((m) => m.ScrollTrigger.refresh()).catch(() => {});
      };

      // Flug-Events aus MarqueeHero steuern die Sperre.
      window.addEventListener('flight-start', (e) => {
        flying = true;
        if ((e as CustomEvent).detail?.mode === 'in') unlock(); // damit der Flug zum Ziel scrollen kann
      });
      window.addEventListener('flight-done', (e) => {
        flying = false;
        if ((e as CustomEvent).detail?.mode === 'out') {
          window.scrollTo(0, 0);
          lock(); // zurück am Hero → wieder sperren
        }
      });

      // Hochscrollen bis ganz oben (Hero) → wieder sperren.
      window.addEventListener(
        'scroll',
        () => {
          if (flying || isLocked()) return;
          if (window.scrollY <= 2) {
            window.scrollTo(0, 0);
            lock();
          }
        },
        { passive: true },
      );

      // Anker-Klicks (Header-Nav, CTA, Hero-Scroll, Footer) abfangen.
      document.addEventListener('click', (ev) => {
        const target = ev.target as Element | null;
        const a = target?.closest?.('a[href^="#"]') as HTMLAnchorElement | null;
        if (!a) return;
        const id = (a.getAttribute('href') || '').slice(1);
        if (id === 'top' || id === 'hero') {
          ev.preventDefault();
          if (!isLocked()) window.scrollTo({ top: 0, behavior: 'smooth' }); // Scroll-Listener sperrt bei 0
          return;
        }
        if (!SECTION_IDS.has(id)) return; // andere Anker (z. B. #main) normal lassen
        ev.preventDefault();
        if (isLocked()) {
          // Am Hero: denselben Flug auslösen wie ein Kachel-Klick.
          if (!flying) window.dispatchEvent(new CustomEvent('request-fly', { detail: { id } }));
        } else {
          // In den Sektionen: einfach sanft hinscrollen.
          document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
      } // Ende Startseiten-Gate
    </script>

    <style>
      .skip-link {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 200;
        transform: translateY(-200%);
        background: var(--color-accent);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
        font-family: var(--font-display);
        transition: transform 0.2s ease;
      }
      .skip-link:focus { transform: translateY(0); }

      .grid-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
      }
      .anchor-top { position: absolute; top: 0; }
    </style>
  </body>
</html>
