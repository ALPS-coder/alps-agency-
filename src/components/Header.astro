---
import { useTranslations, defaultLang, type Lang } from '../i18n';
const { lang = defaultLang } = Astro.props as { lang?: Lang };
const t = useTranslations(lang);
const links = [
  { href: '#services', label: t('nav.services') },
  { href: '#work', label: t('nav.work') },
  { href: '#pricing', label: t('nav.pricing') },
  { href: '#faq', label: t('nav.faq') },
  { href: '#contact', label: t('nav.contact') },
];
---
<header id="site-header" class="site-header">
  <a href="#top" class="brand" aria-label="Alps Agency — Startseite">
    <svg class="brand-mark" viewBox="0 0 48 32" aria-hidden="true">
      <defs>
        <linearGradient id="brand-peak" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#eef2ff" />
          <stop offset="0.55" stop-color="#9fb4ff" />
          <stop offset="1" stop-color="#1a3fff" />
        </linearGradient>
      </defs>
      <path d="M2 30 L17 6 L24 17 L31 4 L46 30 Z" fill="url(#brand-peak)" />
    </svg>
    <span class="brand-word"><strong>ALPS</strong><em>AGENCY</em></span>
  </a>

  <nav class="nav-desktop" aria-label="Hauptnavigation">
    {links.map((l) => <a href={l.href} class="nav-link">{l.label}</a>)}
  </nav>

  <div class="header-actions">
    <a href="#contact" class="btn-primary btn-sm">{t('nav.cta')}</a>
    <button
      id="menu-toggle"
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label={t('nav.menu_open')}
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="mobile-nav" class="nav-mobile glass" aria-label="Mobile Navigation" hidden>
    {links.map((l) => <a href={l.href} class="nav-link-mobile">{l.label}</a>)}
    <a href="#contact" class="btn-primary">{t('nav.cta')}</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem clamp(1.25rem, 5vw, 5rem);
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  .site-header.is-scrolled {
    background: rgba(10, 22, 40, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
  .brand { display: inline-flex; align-items: center; gap: 0.65rem; }
  .brand-mark {
    width: 2.4rem;
    height: auto;
    filter: drop-shadow(0 0 10px rgba(26, 63, 255, 0.45));
  }
  .brand-word {
    font-family: var(--font-display);
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    color: #fff;
  }
  .brand-word strong { font-weight: 700; font-size: 1.05rem; letter-spacing: 0.02em; }
  .brand-word em {
    font-style: normal;
    font-weight: 500;
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .nav-desktop { display: none; gap: 2rem; }
  .nav-link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-muted);
    position: relative;
    transition: color 0.25s ease;
  }
  .nav-link:hover { color: #fff; }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.45rem;
    width: 0;
    height: 2px;
    background: var(--color-accent-bright);
    transition: width 0.25s ease;
  }
  .nav-link:hover::after { width: 100%; }

  .header-actions { display: flex; align-items: center; gap: 0.75rem; }
  .btn-sm { padding: 0.6rem 1.1rem; font-size: 0.9rem; }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 2.7rem;
    height: 2.7rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.6rem;
    background: rgba(255, 255, 255, 0.03);
  }
  .menu-toggle span {
    display: block;
    width: 1.2rem;
    height: 2px;
    background: #fff;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    position: absolute;
    top: 100%;
    left: clamp(1.25rem, 5vw, 5rem);
    right: clamp(1.25rem, 5vw, 5rem);
    margin-top: 0.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .nav-mobile[hidden] { display: none; }
  .nav-link-mobile {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: #fff;
  }

  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
    .menu-toggle { display: none; }
    .nav-mobile { display: none !important; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 40);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  if (toggle && mobileNav) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      mobileNav.hidden = !open;
    };
    toggle.addEventListener('click', () => setOpen(toggle.getAttribute('aria-expanded') !== 'true'));
    mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  }
</script>
