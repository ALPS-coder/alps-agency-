---
import { Image } from 'astro:assets';
import logo from '../assets/alps-logo.jpg';
import MarqueeHero from './ui/MarqueeHero';
import { useTranslations, defaultLang, type Lang } from '../i18n';
const { lang = defaultLang } = Astro.props as { lang?: Lang };
const t = useTranslations(lang);

// Kacheln für den 3D-Marquee = Screenshots der eigenen Sektionen, in der aktiven Sprache.
// Deutsch liegt unter /marquee/, übrige Sprachen unter /marquee/<lang>/.
// Mehrfach wiederholt, damit alle 4 Spalten gut gefüllt sind.
const marqueeDir = lang === defaultLang ? '/marquee' : `/marquee/${lang}`;
// Beispiele-Kachel öffnet das Beispiele-Overlay (kein Sektions-Flug). Erreichbar nur hier
// im Marquee oder über den „Web Design"-Klick in den Referenzen.
const marqueeBase = [
  `${marqueeDir}/services.webp`,
  `${marqueeDir}/work.webp`,
  `${marqueeDir}/beispiele.webp`,
  `${marqueeDir}/pricing.webp`,
  `${marqueeDir}/faq.webp`,
  `${marqueeDir}/contact.webp`,
  `${marqueeDir}/hero.webp`,
];
const marqueeImages = Array.from({ length: 32 }, (_, i) => marqueeBase[i % marqueeBase.length]);
---
<section id="hero" class="hero" aria-label={t('hero.title_pre') + ' ' + t('hero.title_accent')}>
  <!-- 3D-Marquee als bewegter Hero-Hintergrund (eigene Sektions-Screenshots) -->
  <div class="hero-bg" data-scene="bg" aria-hidden="true">
    <MarqueeHero client:load images={marqueeImages} className="hero-marquee" backLabel={t('hero.back')} />
  </div>

  <!-- Verlauf: links dunkel (Lesbarkeit), unten Übergang -->
  <div class="hero-veil" aria-hidden="true"></div>

  <!-- Inhalt — alles linksbündig -->
  <div class="hero-content">
    <div class="hero-logo logo-mask" data-reveal>
      <Image src={logo} alt="Alps Agency" width={240} height={240} loading="eager" />
    </div>
    <p class="eyebrow" data-reveal>{t('hero.badge')}</p>
    <h1 class="h-hero hero-title" data-hero-title>
      <span class="line-mask"><span class="line" data-line="pre">{t('hero.title_pre')}</span></span>
      <span class="line-mask"><span class="line accent text-glow" data-line="accent">{t('hero.title_accent')}</span></span>
      <span class="title-glare" aria-hidden="true"></span>
    </h1>
    <p class="hero-sub" data-reveal>{t('hero.subtitle')}</p>
    <div class="hero-cta" data-reveal>
      <a href="#contact" class="shiny-cta"><span>{t('hero.cta_primary')}</span></a>
      <a href="#work" class="btn-ghost">{t('hero.cta_secondary')}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 7rem clamp(1.25rem, 5vw, 5rem) 6rem;
  }

  /* 3D-Marquee-Hintergrund */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    will-change: transform;
    perspective: 1400px; /* Tiefe für den Maus-Parallax */
  }
  .hero-bg :global(.hero-marquee) {
    width: 100%;
    height: 100%;
    border-radius: 0;
    opacity: 1; /* voll sichtbar — Sektionen klar als Website-Panels erkennbar */
    transform: scale(1.06); /* Ruhezustand (leichter Zoom gegen Ränder beim Kippen) */
    transform-style: preserve-3d;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
    /* Rand-Fade / Vignette: nur ein dezenter Ausklang an den Rändern — der Marquee
       bleibt großflächig klar erkennbar (solider Kern bis 78%, sanft bis zum Rand). */
    -webkit-mask-image: radial-gradient(135% 135% at 50% 42%, #000 78%, transparent 100%);
    mask-image: radial-gradient(135% 135% at 50% 42%, #000 78%, transparent 100%);
  }

  /* Verlauf — deutlich leichter, damit der Marquee klar erkennbar bleibt; links nur
     so viel Abdunklung, dass der Text lesbar ist, rechts fast frei. */
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(6, 15, 28, 0.82) 0%,
        rgba(8, 18, 34, 0.5) 32%,
        rgba(10, 22, 40, 0.18) 60%,
        rgba(10, 22, 40, 0.06) 100%),
      linear-gradient(to bottom,
        rgba(6, 15, 28, 0.45) 0%,
        rgba(10, 22, 40, 0.1) 24%,
        rgba(10, 22, 40, 0.2) 60%,
        var(--color-night) 100%);
  }

  /* Inhalt linksbündig */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 42rem;
    text-align: left;
    will-change: transform, opacity;
    /* Klicks reichen durch den Text auf die Marquee-Kacheln dahinter durch — sonst sind
       die Kacheln hinter Überschrift/Absatz NICHT anklickbar (Flug startet nicht). Nur die
       wirklich interaktiven Elemente (CTA-Buttons) fangen Klicks wieder ab. */
    pointer-events: none;
  }
  .hero-content .hero-cta a {
    pointer-events: auto;
  }

  /* Während eine Kachel herausfliegt: Hero-Inhalt + Veil weich wegblenden */
  .hero.flying .hero-content,
  .hero.flying .hero-veil {
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .hero-logo {
    width: clamp(140px, 16vw, 200px);
    margin-bottom: 2rem;
  }
  .hero-logo :global(img) {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 0 32px rgba(26, 63, 255, 0.28));
  }

  .eyebrow { margin-bottom: 1.25rem; }

  .hero-title {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.08em;
    margin: 0 0 1.6rem;
    font-weight: 700;
  }

  .line-mask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em; /* descender-Spielraum */
  }

  /* Diagonaler Licht-Glanz, der EINMAL über die ganze Headline wischt (Wow-Akzent).
     screen-Blend = lichtet Text + Hintergrund auf, ohne etwas zu verdecken. */
  .title-glare {
    position: absolute;
    inset: -12% -6%;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transform: translateX(-130%);
    background: linear-gradient(105deg,
      transparent 42%, rgba(199, 214, 255, 0.55) 50%, transparent 58%);
    mix-blend-mode: screen;
  }
  .title-glare.sweep {
    animation: title-glare 1.15s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes title-glare {
    0%   { transform: translateX(-130%); opacity: 0; }
    18%  { opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translateX(130%); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .title-glare.sweep { animation: none; }
  }
  .hero-title .accent {
    /* Breiterer Verlauf + background-size, damit ein Licht-Sweep durch den Text
       wandern kann (background-position-Animation). */
    background: linear-gradient(110deg,
      #ffffff 0%, #c3d0ff 28%, #1a3fff 48%, #c3d0ff 68%, #ffffff 100%);
    background-size: 220% 100%;
    background-position: 50% 0;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  /* Einmaliger Licht-Sweep nach dem Reveal … */
  .hero-title .accent.lit {
    animation: accent-sweep 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  /* … danach dezentes „Atmen" des Verlaufs (Endlos, sehr langsam). */
  .hero-title .accent.breathe {
    animation: accent-breathe 7s ease-in-out infinite;
  }
  @keyframes accent-sweep {
    0%   { background-position: 165% 0; }
    100% { background-position: 50% 0; }
  }
  @keyframes accent-breathe {
    0%, 100% { background-position: 44% 0; }
    50%      { background-position: 64% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title .accent.lit,
    .hero-title .accent.breathe { animation: none; }
  }

  .hero-sub {
    max-width: 34rem;
    margin: 0 0 2.5rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
  }

  .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; }


  /* „Magischer" Umriss-Glow auf dem Sekundär-Button („Unsere Arbeiten").
     Zeitgesteuert per JS: startet nach 35 s, leuchtet langsam auf, klingt
     über ~4 s wieder aus — als wiederkehrender Loop (sanfter Klick-Anreiz).
     Weiß-goldener „Feenstaub"-Schein auf Rand + innerem Saum. */
  .hero-cta .btn-ghost.magic {
    animation: hero-magic 4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: box-shadow, border-color;
  }
  @keyframes hero-magic {
    0% {
      box-shadow: 0 0 0 0 rgba(255, 232, 160, 0);
      border-color: rgba(150, 175, 255, 0.32);
    }
    25% {
      box-shadow:
        0 0 12px 1px rgba(255, 236, 175, 0.35),
        0 0 26px 4px rgba(255, 210, 120, 0.18),
        inset 0 0 10px rgba(255, 240, 190, 0.18);
      border-color: rgba(255, 240, 205, 0.7);
    }
    50% {
      box-shadow:
        0 0 22px 3px rgba(255, 240, 185, 0.62),
        0 0 52px 9px rgba(255, 214, 130, 0.42),
        inset 0 0 14px rgba(255, 244, 200, 0.3);
      border-color: rgba(255, 247, 222, 0.96);
    }
    66% {
      /* kurzes magisches Flackern, bevor es ausklingt */
      box-shadow:
        0 0 16px 2px rgba(255, 238, 180, 0.5),
        0 0 40px 7px rgba(255, 214, 130, 0.3),
        inset 0 0 11px rgba(255, 242, 195, 0.22);
      border-color: rgba(255, 244, 214, 0.82);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(255, 232, 160, 0);
      border-color: rgba(150, 175, 255, 0.32);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-cta .btn-ghost.magic { animation: none; }
  }

  /* Klick auf „Unsere Arbeiten": Button schrumpft smooth zusammen und verschwindet
     (danach per JS auf display:none → er ist bis zum Reload weg). */
  .hero-cta .btn-ghost.vanish {
    transform: scale(0.25);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.5, 0, 0.75, 0), opacity 0.45s ease;
  }

  /* Mobile: kräftigerer Veil, Text gut lesbar über dem Berg */
  @media (max-width: 768px) {
    .hero-veil {
      background:
        linear-gradient(to bottom,
          rgba(6, 15, 28, 0.72) 0%,
          rgba(10, 22, 40, 0.42) 38%,
          rgba(10, 22, 40, 0.62) 74%,
          var(--color-night) 100%);
    }
    .hero-content { max-width: none; }
    /* Handy: 3D-Marquee bleibt als Deko sichtbar, ist aber NICHT interaktiv
       (kein Kachel-Flug/Tap) — Touches gehen durch, normales Scrollen bleibt. */
    .hero-bg { pointer-events: none; }
  }
  @media (max-width: 480px) {
    .hero-cta .shiny-cta, .hero-cta .btn-ghost { width: 100%; justify-content: center; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hero = document.getElementById('hero');

  function revealContent() {
    if (!hero) return;
    const intro = hero.querySelectorAll<HTMLElement>('.hero-logo, .eyebrow');
    const outro = hero.querySelectorAll<HTMLElement>('.hero-sub, .hero-cta');
    const lines = hero.querySelectorAll<HTMLElement>('.line');
    const accent = hero.querySelector<HTMLElement>('.line.accent');
    const glare = hero.querySelector<HTMLElement>('.title-glare');

    if (reduceMotion) {
      gsap.set([...intro, ...outro], { opacity: 1, y: 0 });
      gsap.set(lines, { yPercent: 0 });
      accent?.classList.add('breathe');
      return;
    }

    gsap.set(lines, { yPercent: 105 });

    const tl = gsap.timeline({ delay: 0.2 });
    /* Logo + Eyebrow faden zuerst herauf … */
    tl.fromTo(intro,
      { y: 24, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.12, ease: 'power3.out' });
    /* … dann gleitet die Headline zeilenweise hinter ihrer Maske herauf … */
    tl.to(lines,
      { yPercent: 0, duration: 0.85, stagger: 0.14, ease: 'power3.out' },
      '-=0.35');
    /* … und Subtitle, CTA & Scroll faden zum Schluss nach. */
    tl.fromTo(outro,
      { y: 26, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power3.out' },
      '-=0.5');
    tl.add(() => {
      glare?.classList.add('sweep');
      accent?.classList.add('lit');
      accent?.addEventListener('animationend', () => {
        accent.classList.remove('lit');
        accent.classList.add('breathe');
      }, { once: true });
    });
  }
  try { revealContent(); }
  catch {
    hero?.querySelectorAll<HTMLElement>('.hero-logo, .eyebrow, .hero-sub, .hero-cta, .line')
      .forEach((el) => (el.style.opacity = '1'));
  }

  /* Hero faded beim Scrollen sanft weg + schiebt hoch */
  if (!reduceMotion && hero) {
    gsap.to('.hero-content', {
      yPercent: -16, opacity: 0, ease: 'none',
      scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom 35%', scrub: true },
    });
    /* Scroll-gekoppelt: Marquee-Hintergrund schiebt hoch UND zoomt/rotiert dezent mit,
       sodass der Hero beim Verlassen lebendig „mitatmet" statt nur statisch wegzufaden.
       Läuft auf .hero-bg (Wrapper) — kollidiert NICHT mit dem Maus-Parallax auf .hero-marquee. */
    gsap.fromTo('.hero-bg',
      { scale: 1, rotation: 0 },
      {
        yPercent: -10, scale: 1.12, rotation: 1.5, ease: 'none',
        scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: true },
      },
    );
    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  /* Sekundär-Button „Unsere Arbeiten":
     (1) Loop-Glow ab 35 s Verweildauer (sanfter Klick-Anreiz).
     (2) Klick → Navigation unterbinden, Button schrumpft smooth weg, dann leuchten
         die Work-Kacheln im 3D-Marquee magisch auf (~5 s). Button bleibt bis Reload weg. */
  {
    const ghost = hero?.querySelector<HTMLElement>('.hero-cta .btn-ghost');
    if (ghost) {
      let magicStart = 0, magicEnd = 0, magicInterval = 0;

      // (1) Loop-Glow — nur wenn Bewegung erlaubt ist.
      if (!reduceMotion) {
        const START_MS = 35000; // erst nach 35 s auf der Seite
        const GLOW_MS = 4000;   // Dauer eines Aufleuchtens
        const REST_MS = 10000;  // Ruhepause zwischen den Loops
        const pulse = () => {
          ghost.classList.remove('magic');
          void ghost.offsetWidth;        // Reflow → Animation lässt sich neu starten
          ghost.classList.add('magic');
          magicEnd = window.setTimeout(() => ghost.classList.remove('magic'), GLOW_MS);
        };
        magicStart = window.setTimeout(() => {
          pulse();
          magicInterval = window.setInterval(pulse, GLOW_MS + REST_MS);
        }, START_MS);
      }

      // (2) Klick-Verhalten.
      const TILE_GLOW_MS = 5000;
      const igniteWorkTiles = () => {
        const imgs = document.querySelectorAll<HTMLImageElement>(
          '.hero-marquee img[src*="work.webp"]',
        );
        imgs.forEach((img) => {
          const wrap = img.closest('.group');
          if (!wrap) return;
          wrap.classList.remove('marquee-magic');
          void (wrap as HTMLElement).offsetWidth; // Reflow → Neustart möglich
          wrap.classList.add('marquee-magic');
          window.setTimeout(() => wrap.classList.remove('marquee-magic'), TILE_GLOW_MS);
        });
      };

      ghost.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();              // Scroll-Gate / request-fly NICHT auslösen
        e.stopImmediatePropagation?.();
        // Loop-Glow stoppen
        clearTimeout(magicStart);
        clearTimeout(magicEnd);
        clearInterval(magicInterval);
        ghost.classList.remove('magic');

        if (reduceMotion) {
          ghost.style.display = 'none';
          igniteWorkTiles();
          return;
        }
        // Button schrumpft + faded, danach ausblenden und die Magie auf die Kacheln „überspringen"
        ghost.classList.add('vanish');
        window.setTimeout(() => {
          ghost.style.display = 'none';
          igniteWorkTiles();
        }, 500);
      });
    }
  }

  /* Maus-Parallax: der Marquee-Hintergrund kippt sanft mit der Maus (extra 3D-Tiefe) */
  if (!reduceMotion && hero && !window.matchMedia('(pointer: coarse)').matches) {
    const marquee = hero.querySelector('.hero-marquee') as HTMLElement | null;
    if (marquee) {
      const MAX = 7; // max. Neigung in Grad
      let raf = 0;
      const onMove = (e: MouseEvent) => {
        /* Während des Kachel-Flugs NICHT kippen: die hervorgetretene Kachel wird nach
           dem Pop vermessen (Flug-Start) — jede Parallax-Bewegung würde den Klon
           daneben starten lassen. */
        if (hero.classList.contains('flying')) return;
        const r = hero.getBoundingClientRect();
        const nx = (e.clientX - r.left) / r.width - 0.5;  // -0.5 … 0.5
        const ny = (e.clientY - r.top) / r.height - 0.5;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          marquee.style.transform =
            `scale(1.06) rotateY(${nx * MAX}deg) rotateX(${-ny * MAX}deg)`;
        });
      };
      const onLeave = () => {
        if (hero.classList.contains('flying')) return;
        if (raf) cancelAnimationFrame(raf);
        marquee.style.transform = ''; // zurück zum CSS-Ruhezustand (scale 1.06)
      };
      hero.addEventListener('mousemove', onMove);
      hero.addEventListener('mouseleave', onLeave);
    }
  }
</script>
