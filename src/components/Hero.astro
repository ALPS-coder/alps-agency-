---
import { Image } from 'astro:assets';
import logo from '../assets/alps-logo.jpg';
import MarqueeHero from './ui/MarqueeHero';
import { useTranslations, defaultLang, type Lang } from '../i18n';
const { lang = defaultLang } = Astro.props as { lang?: Lang };
const t = useTranslations(lang);

// Kacheln für den 3D-Marquee = Screenshots der eigenen Sektionen.
// Mehrfach wiederholt, damit alle 4 Spalten gut gefüllt sind.
const marqueeBase = [
  '/marquee/services.webp',
  '/marquee/work.webp',
  '/marquee/beispiele.webp',
  '/marquee/pricing.webp',
  '/marquee/faq.webp',
  '/marquee/contact.webp',
  '/marquee/hero.webp',
];
const marqueeImages = Array.from({ length: 32 }, (_, i) => marqueeBase[i % marqueeBase.length]);
---
<section id="hero" class="hero" aria-label={t('hero.title_pre') + ' ' + t('hero.title_accent')}>
  <!-- 3D-Marquee als bewegter Hero-Hintergrund (eigene Sektions-Screenshots) -->
  <div class="hero-bg" data-scene="bg" aria-hidden="true">
    <MarqueeHero client:load images={marqueeImages} className="hero-marquee" />
  </div>

  <!-- Verlauf: links dunkel (Lesbarkeit), unten Übergang -->
  <div class="hero-veil" aria-hidden="true"></div>

  <!-- Inhalt — alles linksbündig -->
  <div class="hero-content">
    <div class="hero-logo logo-mask" data-reveal>
      <Image src={logo} alt="Alps Agency" width={240} height={240} loading="eager" />
    </div>
    <p class="eyebrow" data-reveal>{t('hero.badge')}</p>
    <h1 class="h-hero hero-title" data-hero-title>
      <span class="line" data-line="pre">{t('hero.title_pre')}</span>
      <span class="line accent text-glow" data-line="accent">{t('hero.title_accent')}</span>
      <span class="title-glare" aria-hidden="true"></span>
    </h1>
    <p class="hero-sub" data-reveal>{t('hero.subtitle')}</p>
    <div class="hero-cta" data-reveal>
      <a href="#contact" class="btn-primary">{t('hero.cta_primary')}</a>
      <a href="#work" class="btn-ghost">{t('hero.cta_secondary')}</a>
    </div>
  </div>

  <a href="#services" class="hero-scroll" data-reveal aria-label={t('hero.scroll')}>
    <span class="hero-scroll-label">{t('hero.scroll')}</span>
    <span class="hero-scroll-line"><span class="hero-scroll-dot"></span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 7rem clamp(1.25rem, 5vw, 5rem) 6rem;
  }

  /* 3D-Marquee-Hintergrund */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    will-change: transform;
    perspective: 1400px; /* Tiefe für den Maus-Parallax */
  }
  .hero-bg :global(.hero-marquee) {
    width: 100%;
    height: 100%;
    border-radius: 0;
    opacity: 1; /* voll sichtbar — Sektionen klar als Website-Panels erkennbar */
    transform: scale(1.06); /* Ruhezustand (leichter Zoom gegen Ränder beim Kippen) */
    transform-style: preserve-3d;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
    /* Rand-Fade / Vignette: nur ein dezenter Ausklang an den Rändern — der Marquee
       bleibt großflächig klar erkennbar (solider Kern bis 78%, sanft bis zum Rand). */
    -webkit-mask-image: radial-gradient(135% 135% at 50% 42%, #000 78%, transparent 100%);
    mask-image: radial-gradient(135% 135% at 50% 42%, #000 78%, transparent 100%);
  }

  /* Verlauf — deutlich leichter, damit der Marquee klar erkennbar bleibt; links nur
     so viel Abdunklung, dass der Text lesbar ist, rechts fast frei. */
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(6, 15, 28, 0.82) 0%,
        rgba(8, 18, 34, 0.5) 32%,
        rgba(10, 22, 40, 0.18) 60%,
        rgba(10, 22, 40, 0.06) 100%),
      linear-gradient(to bottom,
        rgba(6, 15, 28, 0.45) 0%,
        rgba(10, 22, 40, 0.1) 24%,
        rgba(10, 22, 40, 0.2) 60%,
        var(--color-night) 100%);
  }

  /* Inhalt linksbündig */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 42rem;
    text-align: left;
    will-change: transform, opacity;
    /* Klicks reichen durch den Text auf die Marquee-Kacheln dahinter durch — sonst sind
       die Kacheln hinter Überschrift/Absatz NICHT anklickbar (Flug startet nicht). Nur die
       wirklich interaktiven Elemente (CTA-Buttons) fangen Klicks wieder ab. */
    pointer-events: none;
  }
  .hero-content .hero-cta a {
    pointer-events: auto;
  }

  /* Während eine Kachel herausfliegt: Hero-Inhalt + Veil weich wegblenden */
  .hero.flying .hero-content,
  .hero.flying .hero-veil,
  .hero.flying .hero-scroll {
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .hero-logo {
    width: clamp(140px, 16vw, 200px);
    margin-bottom: 2rem;
  }
  .hero-logo :global(img) {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 0 32px rgba(26, 63, 255, 0.28));
  }

  .eyebrow { margin-bottom: 1.25rem; }

  .hero-title {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.08em;
    margin: 0 0 1.6rem;
    font-weight: 700;
    /* gemeinsame 3D-Bühne für den Flip-Reveal der Wörter */
    perspective: 900px;
  }

  /* Diagonaler Licht-Glanz, der EINMAL über die ganze Headline wischt (Wow-Akzent).
     screen-Blend = lichtet Text + Hintergrund auf, ohne etwas zu verdecken. */
  .title-glare {
    position: absolute;
    inset: -12% -6%;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transform: translateX(-130%);
    background: linear-gradient(105deg,
      transparent 42%, rgba(199, 214, 255, 0.55) 50%, transparent 58%);
    mix-blend-mode: screen;
  }
  .title-glare.sweep {
    animation: title-glare 1.15s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes title-glare {
    0%   { transform: translateX(-130%); opacity: 0; }
    18%  { opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translateX(130%); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .title-glare.sweep { animation: none; }
  }
  .hero-title .accent {
    /* Breiterer Verlauf + background-size, damit ein Licht-Sweep durch den Text
       wandern kann (background-position-Animation). */
    background: linear-gradient(110deg,
      #ffffff 0%, #c3d0ff 28%, #1a3fff 48%, #c3d0ff 68%, #ffffff 100%);
    background-size: 220% 100%;
    background-position: 50% 0;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  /* Einmaliger Licht-Sweep nach dem Reveal … */
  .hero-title .accent.lit {
    animation: accent-sweep 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  /* … danach dezentes „Atmen" des Verlaufs (Endlos, sehr langsam). */
  .hero-title .accent.breathe {
    animation: accent-breathe 7s ease-in-out infinite;
  }
  @keyframes accent-sweep {
    0%   { background-position: 165% 0; }
    100% { background-position: 50% 0; }
  }
  @keyframes accent-breathe {
    0%, 100% { background-position: 44% 0; }
    50%      { background-position: 64% 0; }
  }

  /* Wort-Masken für den „Schweben"-Reveal (JS wrappt die Wörter zur Laufzeit). */
  .hero-title .word-mask {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    /* etwas Luft, damit blur/descender nicht abgeschnitten werden */
    padding: 0.12em 0.04em;
    margin: -0.12em -0.04em;
  }
  .hero-title .word-inner {
    display: inline-block;
    will-change: transform, opacity, filter;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title .accent.lit,
    .hero-title .accent.breathe { animation: none; }
  }

  .hero-sub {
    max-width: 34rem;
    margin: 0 0 2.5rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
  }

  .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* Scroll-Indikator (linksbündig) */
  .hero-scroll {
    position: absolute;
    z-index: 10;
    bottom: 2rem;
    left: clamp(1.25rem, 5vw, 5rem);
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 2.4rem;
    height: 1.5px;
    background: rgba(255, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }
  .hero-scroll-dot {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    width: 40%;
    background: var(--color-accent-bright);
    border-radius: 2px;
    animation: scroll-dot 2s ease-in-out infinite;
  }
  @keyframes scroll-dot {
    0% { transform: translateX(-100%); }
    60%, 100% { transform: translateX(250%); }
  }

  /* Mobile: kräftigerer Veil, Text gut lesbar über dem Berg */
  @media (max-width: 768px) {
    .hero-veil {
      background:
        linear-gradient(to bottom,
          rgba(6, 15, 28, 0.72) 0%,
          rgba(10, 22, 40, 0.42) 38%,
          rgba(10, 22, 40, 0.62) 74%,
          var(--color-night) 100%);
    }
    .hero-content { max-width: none; }
  }
  @media (max-width: 480px) {
    .hero-cta .btn-primary, .hero-cta .btn-ghost { width: 100%; justify-content: center; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hero = document.getElementById('hero');

  /* Wörter einer Zeile in Masken-Spans wrappen (für den „Schweben"-Reveal).
     Whitespace bleibt als Textknoten erhalten. Gibt die inneren Spans zurück. */
  function splitWords(line: HTMLElement) {
    const text = line.textContent ?? '';
    line.textContent = '';
    const inners: HTMLElement[] = [];
    for (const part of text.split(/(\s+)/)) {
      if (part === '') continue;
      if (/^\s+$/.test(part)) { line.appendChild(document.createTextNode(part)); continue; }
      const mask = document.createElement('span');
      mask.className = 'word-mask';
      const inner = document.createElement('span');
      inner.className = 'word-inner';
      inner.textContent = part;
      mask.appendChild(inner);
      line.appendChild(mask);
      inners.push(inner);
    }
    return inners;
  }

  /* Inszenierter Reveal: Logo/Eyebrow → Headline schwebt Wort für Wort herauf →
     Sub/CTA faden nach → Licht-Sweep über den Akzent, danach dezentes Atmen. */
  function revealContent() {
    if (!hero) return;
    const intro = hero.querySelectorAll<HTMLElement>('.hero-logo, .eyebrow');
    const outro = hero.querySelectorAll<HTMLElement>('.hero-sub, .hero-cta, .hero-scroll');
    const accent = hero.querySelector<HTMLElement>('.line.accent');
    const preLine = hero.querySelector<HTMLElement>('.line[data-line="pre"]');

    if (reduceMotion) {
      gsap.set([...intro, ...outro], { opacity: 1, y: 0 });
      return;
    }

    const preWords = preLine ? splitWords(preLine) : [];
    const accentWords = accent ? splitWords(accent) : [];
    const allWords = [...preWords, ...accentWords];
    const glare = hero.querySelector<HTMLElement>('.title-glare');

    // Wörter klappen aus der Tiefe nach oben in ihre Position (3D-Flip + blur),
    // unten-zentrierter Pivot — passt zum 3D-Marquee dahinter.
    gsap.set(allWords, { transformOrigin: '50% 100%' });

    const tl = gsap.timeline({ delay: 0.9 });
    tl.fromTo(intro,
      { y: 24, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.12, ease: 'power3.out' });
    tl.fromTo(preWords,
      { yPercent: 115, rotateX: -85, opacity: 0, filter: 'blur(10px)' },
      { yPercent: 0, rotateX: 0, opacity: 1, filter: 'blur(0px)',
        duration: 0.75, stagger: 0.08, ease: 'power3.out' },
      '-=0.35');
    tl.fromTo(accentWords,
      { yPercent: 115, rotateX: -85, opacity: 0, filter: 'blur(12px)' },
      { yPercent: 0, rotateX: 0, opacity: 1, filter: 'blur(0px)',
        duration: 0.85, stagger: 0.09, ease: 'power3.out' },
      '-=0.45');
    tl.fromTo(outro,
      { y: 26, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power3.out' },
      '-=0.5');
    /* Endzustand HART festschreiben: alle Inline-Transforms/Filter entfernen, damit
       die Headline garantiert komplett & gestochen scharf sichtbar stehen bleibt. */
    tl.add(() => {
      gsap.set(allWords, { clearProps: 'all' });
      gsap.set([...intro, ...outro], { clearProps: 'transform' });
    });
    /* Licht-Glanz wischt einmal über die ganze Headline … */
    tl.add(() => glare?.classList.add('sweep'), '-=0.05');
    /* … und der Akzent bekommt seinen Sweep, danach das dezente Atmen. */
    tl.add(() => {
      accent?.classList.add('lit');
      accent?.addEventListener('animationend', () => {
        accent.classList.remove('lit');
        accent.classList.add('breathe');
      }, { once: true });
    });
  }
  try { revealContent(); }
  catch {
    hero?.querySelectorAll<HTMLElement>('.hero-logo, .eyebrow, .hero-sub, .hero-cta, .hero-scroll, .line')
      .forEach((el) => (el.style.opacity = '1'));
  }

  /* Hero faded beim Scrollen sanft weg + schiebt hoch */
  if (!reduceMotion && hero) {
    gsap.to('.hero-content', {
      yPercent: -16, opacity: 0, ease: 'none',
      scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom 35%', scrub: true },
    });
    /* Scroll-gekoppelt: Marquee-Hintergrund schiebt hoch UND zoomt/rotiert dezent mit,
       sodass der Hero beim Verlassen lebendig „mitatmet" statt nur statisch wegzufaden.
       Läuft auf .hero-bg (Wrapper) — kollidiert NICHT mit dem Maus-Parallax auf .hero-marquee. */
    gsap.fromTo('.hero-bg',
      { scale: 1, rotation: 0 },
      {
        yPercent: -10, scale: 1.12, rotation: 1.5, ease: 'none',
        scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: true },
      },
    );
    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  /* Maus-Parallax: der Marquee-Hintergrund kippt sanft mit der Maus (extra 3D-Tiefe) */
  if (!reduceMotion && hero && !window.matchMedia('(pointer: coarse)').matches) {
    const marquee = hero.querySelector('.hero-marquee') as HTMLElement | null;
    if (marquee) {
      const MAX = 7; // max. Neigung in Grad
      let raf = 0;
      const onMove = (e: MouseEvent) => {
        /* Während des Kachel-Flugs NICHT kippen: die hervorgetretene Kachel wird nach
           dem Pop vermessen (Flug-Start) — jede Parallax-Bewegung würde den Klon
           daneben starten lassen. */
        if (hero.classList.contains('flying')) return;
        const r = hero.getBoundingClientRect();
        const nx = (e.clientX - r.left) / r.width - 0.5;  // -0.5 … 0.5
        const ny = (e.clientY - r.top) / r.height - 0.5;
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          marquee.style.transform =
            `scale(1.06) rotateY(${nx * MAX}deg) rotateX(${-ny * MAX}deg)`;
        });
      };
      const onLeave = () => {
        if (hero.classList.contains('flying')) return;
        if (raf) cancelAnimationFrame(raf);
        marquee.style.transform = ''; // zurück zum CSS-Ruhezustand (scale 1.06)
      };
      hero.addEventListener('mousemove', onMove);
      hero.addEventListener('mouseleave', onLeave);
    }
  }
</script>
