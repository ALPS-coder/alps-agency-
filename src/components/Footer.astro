---
import { useTranslations, defaultLang, type Lang } from '../i18n';
const { lang = defaultLang } = Astro.props as { lang?: Lang };
const t = useTranslations(lang);

const year = new Date().getFullYear();

const navLinks = [
  { href: '#services', label: t('nav.services') },
  { href: '#work', label: t('nav.work') },
  { href: '#pricing', label: t('nav.pricing') },
  { href: '#faq', label: t('nav.faq') },
  { href: '#contact', label: t('nav.contact') },
];

const email = t('footer.email');
const phone = t('footer.phone');
const waNumber = phone.replace(/[^\d]/g, '');
---
<footer class="site-footer" aria-labelledby="footer-title">
  <h2 id="footer-title" class="sr-only">Alps Agency</h2>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="#top" class="brand" aria-label="Alps Agency — Startseite">
          <svg class="brand-mark" viewBox="0 0 48 32" aria-hidden="true">
            <defs>
              <linearGradient id="footer-peak" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#eef2ff" />
                <stop offset="0.55" stop-color="#9fb4ff" />
                <stop offset="1" stop-color="#1a3fff" />
              </linearGradient>
            </defs>
            <path d="M2 30 L17 6 L24 17 L31 4 L46 30 Z" fill="url(#footer-peak)" />
          </svg>
          <span class="brand-word"><strong>ALPS</strong><em>AGENCY</em></span>
        </a>
        <p class="footer-tagline">{t('footer.tagline')}</p>
      </div>

      <nav class="footer-col" aria-label={t('footer.nav_title')}>
        <h3 class="footer-h">{t('footer.nav_title')}</h3>
        <ul role="list">
          {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </nav>

      <div class="footer-col">
        <h3 class="footer-h">{t('footer.contact_title')}</h3>
        <ul role="list">
          <li><a href={`mailto:${email}`}>{email}</a></li>
          <li><a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a></li>
          <li>
            <a class="footer-wa" href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.13a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.11.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
              {t('footer.whatsapp')}
            </a>
          </li>
        </ul>
      </div>

      <nav class="footer-col" aria-label={t('footer.legal_title')}>
        <h3 class="footer-h">{t('footer.legal_title')}</h3>
        <ul role="list">
          <li><a href="#">{t('footer.imprint')}</a></li>
          <li><a href="#">{t('footer.privacy')}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} Alps Agency. {t('footer.rights')}</p>
      <p class="footer-note">{t('footer.placeholder_note')}</p>
    </div>
  </div>
</footer>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  .site-footer {
    background: var(--color-night-deep);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 5rem) 2rem;
  }
  .footer-inner { max-width: 80rem; margin-inline: auto; }

  .footer-top {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .footer-top { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .footer-top { grid-template-columns: 2fr 1fr 1.3fr 1fr; } }

  .brand { display: inline-flex; align-items: center; gap: 0.65rem; }
  .brand-mark { width: 2.4rem; height: auto; filter: drop-shadow(0 0 10px rgba(26, 63, 255, 0.45)); }
  .brand-word { font-family: var(--font-display); display: flex; align-items: baseline; gap: 0.4rem; color: #fff; }
  .brand-word strong { font-weight: 700; font-size: 1.05rem; letter-spacing: 0.02em; }
  .brand-word em {
    font-style: normal; font-weight: 500; font-size: 0.62rem;
    letter-spacing: 0.32em; text-transform: uppercase; color: var(--color-muted);
  }
  .footer-tagline {
    margin-top: 1rem;
    max-width: 24rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .footer-h {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1rem;
  }
  .footer-col ul { display: flex; flex-direction: column; gap: 0.65rem; }
  .footer-col a {
    color: var(--color-muted);
    font-size: 0.95rem;
    transition: color 0.25s ease;
  }
  .footer-col a:hover { color: #fff; }

  .footer-wa { display: inline-flex; align-items: center; gap: 0.5rem; }
  .footer-wa svg { width: 1.1rem; height: 1.1rem; color: var(--color-whatsapp); }

  .footer-bottom {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .footer-note { opacity: 0.7; }
</style>
